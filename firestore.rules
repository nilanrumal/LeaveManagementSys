rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow authenticated users to perform operations on the users collection
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }

    // Allow authenticated users to perform operations on the leaveRequests collection
    match /leaveRequests/{requestId} {
      allow read, write: if request.auth != null;
    }
  }
}
